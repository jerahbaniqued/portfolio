  .contact-card .cc-icon { font-size: 1.3rem; }
  .contact-card .cc-label { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); font-weight: 600; }
  .contact-card .cc-val { font-size: 0.82rem; color: rgba(255,255,255,0.75); text-align: center; }
  .avail-badge { display: inline-block; font-size: 0.75rem; color: var(--gold); border: 1px solid rgba(201,168,76,0.4); padding: 0.5rem 1.4rem; letter-spacing: 0.08em; }


  .btn-outline { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(201,168,76,0.5); color: var(--goldl); font-weight: 500; font-size: 0.82rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.8rem 1.8rem; text-decoration: none; transition: all 0.2s; }

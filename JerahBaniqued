  .tool-pill { background: var(--navy); color: rgba(255,255,255,0.8); font-size: 0.72rem; padding: 0.4rem 0.9rem; font-weight: 500; letter-spacing: 0.03em; border: 1px solid rgba(201,168,76,0.2); transition: all 0.2s; }

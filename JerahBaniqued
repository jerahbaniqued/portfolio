  .contact-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(201,168,76,0.2); padding: 1.4rem 1rem; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
